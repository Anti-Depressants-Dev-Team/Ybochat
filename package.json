{
  "name": "ybochat",
  "version": "1.4.5",
  "description": "Multi-platform chat client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:dir": "electron-builder --dir",
    "icon": "node scripts/make-icon.js"
  },
  "keywords": [],
  "author": "Ybochat <ybochat@github.com>",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.33.5",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.ybochat.app",
    "productName": "Ybochat",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "icon": "build/icons",
      "category": "Network"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "chat.png",
      "scripts/**",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
